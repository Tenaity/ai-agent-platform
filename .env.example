# Runtime API
SNP_ENVIRONMENT=local
SNP_LOG_LEVEL=INFO
SNP_CHECKPOINT_BACKEND=none
SNP_CHECKPOINT_NAMESPACE=

# Future LangSmith integration. Do not commit real keys.
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=
SNP_TRACE_SAMPLE_RATE=1.0

# Qdrant retriever adapter (PR-019). Do not commit real URLs or API keys.
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=customer_service_knowledge

# Telegram local polling demo (PR-022). Do not commit a real bot token.
TELEGRAM_BOT_TOKEN=
TELEGRAM_POLL_TIMEOUT_SECONDS=30
TELEGRAM_AGENT_ID=customer_service
TELEGRAM_TENANT_ID=demo
RUNTIME_API_BASE_URL=http://localhost:8000
